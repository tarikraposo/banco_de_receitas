{
  "name": "receitas",
  "version": "0.0.0",
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --base-href=/receitas/ && copy dist\\receitas\\browser\\index.html dist\\receitas\\browser\\404.html",
    "deploy": "npx angular-cli-ghpages --dir=dist/receitas/browser",
    "deploy:prod": "npm run build:prod && angular-cli-ghpages --dir=dist/receitas/browser"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.4.2",
  "dependencies": {
    "@angular/cdk": "~21.1.5",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "~21.1.5",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@supabase/supabase-js": "^2.98.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.5",
    "@angular/cli": "^21.1.5",
    "@angular/compiler-cli": "^21.1.0",
    "@angular/material": "^21.1.5",
    "angular-cli-ghpages": "^3.0.2",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
